# ===========================================
# Recommendation Service Environment Config
# Copy this file to .env and fill in your values
# ===========================================

# Server Configuration
PORT=5001
NODE_ENV=development
SERVICE_NAME=recommendation-service

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cinescope?retryWrites=true&w=majority
MONGO_URI_FALLBACK=mongodb://localhost:27017/cinescope

# TMDB API Configuration (for seeding movies)
TMDB_API_KEY=your_tmdb_api_key_here

# Service Discovery (optional - for inter-service communication)
USER_SERVICE_URL=http://localhost:5000

# Recommendation Configuration
RECOMMENDATION_LIMIT=20
MIN_VOTE_COUNT=10
MIN_VOTE_AVERAGE=0
