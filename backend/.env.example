# ===========================================
# CineScope API Gateway Configuration
# Copy this file to .env and fill in your values
# ===========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cinescope?retryWrites=true&w=majority
MONGO_URI_FALLBACK=mongodb://localhost:27017/cinescope

# TMDB API Configuration
TMDB_API_KEY=your_tmdb_api_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_use_a_long_random_string
JWT_EXPIRES_IN=7d

# OTP Configuration
OTP_SECRET=your_otp_secret_here

# Email (SMTP) Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="CineScope <your_email@gmail.com>"

# ===========================================
# Microservice URLs
# ===========================================
RECOMMENDATION_SERVICE_URL=http://localhost:5001
